#ifndef FIXEDSIZESTACK_H
#define FIXEDSIZESTACK_H

#include<iostream>


template<class T>
class FixedSizeStack{
private:
    T *items;
    int n;
    int capacity;

public:
    FixedSizeStack(int capacity);
    void push(T item);
    bool pop(T &out);
    int size();
    bool isEmpty();

    ~FixedSizeStack();
};

template<class T>
FixedSizeStack<T>::FixedSizeStack(int capacity)
{
    items = new T[capacity];
    n = 0;
    this->capacity = capacity;
}

template<class T>
void FixedSizeStack<T>::push(T elt)
{
    if (n >= capacity)
    {
        std::cerr << "FULL STACK : NO SPACE TO PUSH" << std::endl;
    }
    else
    {
        items[n] = elt;
        n = n+1;
    }
}


template<class T>
bool FixedSizeStack<T>::pop(T &out)
{
    if (n == 0)
    {
        std::cerr << "STACK EMPTY : NO ELEMENT TO POP" << std::endl;
        return false;
    }
    else
    {
        n = n-1;
        out = items[n];
        return true;
    }
}


template<class T>
bool FixedSizeStack<T>::isEmpty()
{
    return n==0;
}

template<class T>
int FixedSizeStack<T>::size()
{
    return n;
}

template<class T>
FixedSizeStack<T>::~FixedSizeStack()
{
  delete [] items;
}


#endif
