#ifndef QUEUE_H
#define QUEUE_H

#include <iostream>

template<class T>
class Queue{
private:
  struct Node{
    T data;
    Node *next;
    Node(T data, Node *next)
    {
      this->data = data;
      this->next = next;
    }
  };
  Node *first, *last;
  int n;

public:
  Queue();
  void enqueue(T elt);
  bool dequeue(T &elt);
  bool isEmpty();
  int size();

  ~Queue();
};


template<class T>
Queue<T>::Queue()
{
  first = nullptr;
  last = nullptr;
  n=0; 
}

template<class T>
void Queue<T>::enqueue(T elt)
{
  if (n==0)
    {
      first = new Node(elt, nullptr);
      last = first;
      n = n+1;
    }
  else
    {
      last->next = new Node(elt, nullptr);
      last = last->next;
      n = n+1;
    }
}


template<class T>
bool Queue<T>::dequeue(T &elt)
{
  if (n == 0)
    {
      return false;
    }
  else
    {
      Node *oldfirst;
      elt = first->data;
      oldfirst = first;
      first = first->next;
      n = n-1;
      if (n == 0)
	{
	  last = nullptr;
	}
      delete oldfirst;
      return true;
    }
}


template<class T>
bool Queue<T>::isEmpty()
{
  return n==0;
}

template<class T>
int Queue<T>::size()
{
  return n;
}


template<class T>
Queue<T>::~Queue()
{
  Node *node_deleted;
  for(Node *q = first; q != nullptr;)
    {
      node_deleted = q;
      q = q->next;
      delete node_deleted;
    }
}

#endif
